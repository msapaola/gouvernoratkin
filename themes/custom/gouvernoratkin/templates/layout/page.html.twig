<!-- Navigation area start -->
    <header>
    <nav class="navbar navbar-expand-lg">
      <div class="container">
        {% if page.logo %}
          {{page.logo}}
        {% endif %}
        
        <!-- Boutons à droite sur mobile (recherche et contact) -->
        <div class="d-flex d-lg-none mobile-actions">
          <button class="popup-button"><i class="fas fa-search"></i></button>
          <a href="/contact" class="btn-contact-mobile">
            <i class="fas fa-envelope"></i>
          </a>
        </div>
        
        <!-- Bouton hamburger -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
          <i class="fas fa-bars"></i>
        </button>
        
        <!-- Menu principal -->
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
          {% if page.menu %}
            {{page.menu}}
          {% endif %}
          
          <!-- Boutons à droite sur desktop (recherche et contact) -->
          <div class="d-none d-lg-flex align-items-center">
            <button class="popup-button"><i class="fas fa-search"></i></button>
            <a href="/Contact" class="btn btn-contact">Contact</a>
          </div>
        </div>
      </div>
    </nav>
  </header>

 <!-- Navigation area end --> 
  
 
  {% if page.top_menu %}
  
      <div class="container">
          {{page.top_menu}}
      </di>
  
   {% endif %}
   
   <!--========== BEGIN CONTENT ==========--> 
				{% if page.content %}
					{{ page.content }}
				{% endif %}
		
<!--========== END CONTENT ==========--> 
 <!-- Welcome Banner Area Start -->
 {% if page.welcome %}
    <!-- Section Bienvenue -->
  <section class="welcome-section" id="welcome">
     {{page.welcome}}
    <div class="welcome-overlay"></div>
    
    <div class="container welcome-content">
      <div class="row">
        <div class="col-lg-8 col-md-10">
          <h1 class="welcome-title">Bienvenue à Kinshasa</h1>
          <p class="welcome-subtitle">
            Découvrez la vibrante capitale de la République Démocratique du Congo, 
            qui se réinvente chaque jour, mêlant tradition et modernité pour construire une ville tournée vers l’avenir.
          </p>
          
          <div class="highlights-carousel">
            <div class="highlight-item">
              <h5 class="highlight-title"><i class="fas fa-heartbeat me-2"></i>Kinshasa, au cœur du changement</h5>
              <p class="highlight-text">Centre culturel et économique rayonnant sur toute l'Afrique centrale.</p>
            </div>
          </div>
          
          <div class="social-media-mobile">
            <div class="social-container">
              <p class="social-text">Nous suivre</p>
              <div class="social-icons-wrapper">
                <a href="https://x.com/gouvernoratk?s=21&t=NMje2EnuC86EYrQumPVdFQ" class="social-icon"><i class="fab fa-twitter"></i></a>
                <a href="https://www.facebook.com/GouvKinshasa?mibextid=wwXIfr&mibextid=wwXIfr" class="social-icon"><i class="fab fa-facebook-f"></i></a>
                <a href="https://www.instagram.com/gouvernoratk?igsh=MW0zd3NlN3NudTU5dg%3D%3D&utm_source=qr" class="social-icon"><i class="fab fa-instagram"></i></a>
                <a href="https://youtube.com/@gouvernoratdekinshasa?si=MwKmbGHxB-m8FxNb" class="social-icon"><i class="fab fa-youtube"></i></a>
                <a href="https://www.tiktok.com/@gouvernoratk?_t=ZM-8uqtzzkLRLi&_r=1" class="social-icon"><i class="fab fa-tiktok"></i></a>
              </div>
            </div>
          </div>
          
          <div class="cta-buttons">
            <a href="#features" class="btn btn-primary-custom">Découvrir notre ville</a>
            <a href="/contact" class="btn btn-secondary-custom"><i class="fas fa-envelope"></i></a>
          </div>
        </div>
      </div>
    </div>
    
    <div class="social-media-desktop">
      <p class="social-text">Nous suivre</p>
      <a href="https://x.com/gouvernoratk?s=21&t=NMje2EnuC86EYrQumPVdFQ" class="social-icon"><i class="fab fa-twitter"></i></a>
      <a href="https://www.facebook.com/GouvKinshasa?mibextid=wwXIfr&mibextid=wwXIfr" class="social-icon"><i class="fab fa-facebook-f"></i></a>
      <a href="https://www.instagram.com/gouvernoratk?igsh=MW0zd3NlN3NudTU5dg%3D%3D&utm_source=qr" class="social-icon"><i class="fab fa-instagram"></i></a>
      <a href="https://youtube.com/@gouvernoratdekinshasa?si=MwKmbGHxB-m8FxNb" class="social-icon"><i class="fab fa-youtube"></i></a>
      <a href="https://www.tiktok.com/@gouvernoratk?_t=ZM-8uqtzzkLRLi&_r=1" class="social-icon"><i class="fab fa-tiktok"></i></a>
    </div>
    
    <a href="#features" class="scroll-indicator">
      <i class="fas fa-chevron-down"></i>
    </a>
  </section>

  <!-- Section des caractéristiques -->
  <section class="features-section" id="features">
    <div class="container">
      <div class="row">
        <div class="col-md-3 col-sm-6">
          <div class="feature-card blue">
            <div class="feature-icon blue">
              <i class="fas fa-newspaper"></i>
            </div>
            <h3 class="feature-title">Actualités</h3>
            <p class="feature-desc">Suivez les dernières informations et annonces officielles du gouvernorat de Kinshasa.</p>
          </div>
        </div>
        
        <div class="col-md-3 col-sm-6">
          <div class="feature-card red">
            <div class="feature-icon red">
              <i class="fas fa-calendar-alt"></i>
            </div>
            <h3 class="feature-title">Événements</h3>
            <p class="feature-desc">Découvrez notre agenda culturel, sportif et officiel pour ne rien manquer à Kinshasa.</p>
          </div>
        </div>
        
        <div class="col-md-3 col-sm-6">
          <div class="feature-card green">
            <div class="feature-icon green">
              <i class="fas fa-info-circle"></i>
            </div>
            <h3 class="feature-title">À propos de Kinshasa</h3>
            <p class="feature-desc">Partez à la découverte de son passé, de ses paysages et de sa richesse culturelle.</p>
          </div>
        </div>
        
        <div class="col-md-3 col-sm-6">
          <div class="feature-card yellow">
            <div class="feature-icon yellow">
              <i class="fas fa-monument"></i>
            </div>
            <h3 class="feature-title">Culture et Patrimoine</h3>
            <p class="feature-desc">Plongez dans la richesse culturelle et le patrimoine historique de Kinshasa.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
   {% endif %}
 <!-- Welcome Banner Area End -->

