<!--========== BEGIN TWIG CLASSES ==========-->
 {% 
  set logo_classes = (page.logo) ? 'col-3' : ''
  %} 

  {% 
  set menu_classes = (page.menu) ? 'col-6' : ''
  %} 

  {% 
  set sidebar_classes = (page.sidebar) ? 'col-3' : ''
  %} 
  
  {% 
  set singlepost_classes = (page.singlepost) ? 'blog-details pt-100' : ''  
  %}

<!--========== END TWIG CLASSES ==========-->
<!-- Navigation area start -->
    <header>
    <nav class="navbar navbar-expand-lg">
      <div class="container">
        {% if page.logo %}
          {{page.logo}}
        {% endif %}
        
        <div class="d-flex d-lg-none mobile-actions">
          <button class="popup-button"><i class="fas fa-search"></i></button>
          <a href="/contact" class="btn-contact-mobile">
            <i class="fas fa-envelope"></i>
          </a>
        </div>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
          <i class="fas fa-bars"></i>
        </button>
        
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
          {% if page.menu %}
            {{page.menu}}
          {% endif %}
          
          <div class="d-none d-lg-flex align-items-center">
            <button class="popup-button"><i class="fas fa-search"></i></button>
            <a href="/Contact" class="btn btn-contact">Contact</a>
          </div>
        </div>
      </div>
    </nav>
  </header>
<!-- Navigation area end -->

{% if page.top_menu %}
    <div class="container">
        {{page.top_menu}}
    </div>
{% endif %}

<!--========== BEGIN CONTENT ==========-->
{% if page.content %}
    {{ page.content }}
{% endif %}
<!--========== END CONTENT ==========-->

<!-- ===== BANNIÈRE SERVICES AUX CITOYENS ===== -->
<div class="services-page-header">
  <div class="container">
    <nav aria-label="breadcrumb" class="services-breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/"><i class="fas fa-home"></i> Accueil</a></li>
        <li class="breadcrumb-item active" aria-current="page">Services aux citoyens</li>
      </ol>
    </nav>
    <h1 class="services-page-title">
      <i class="fas fa-hands-helping me-3"></i>Services aux citoyens
    </h1>
    <p class="services-page-subtitle">Retrouvez l'ensemble des démarches et services proposés par le Gouvernorat de Kinshasa à la population kinoise.</p>
    
    <!-- Barre de recherche principale -->
    <div class="services-search-bar">
      <form action="" method="get" class="services-search-form" id="services-search-form">
        <div class="search-input-wrapper">
          <i class="fas fa-search search-icon-decorative"></i>
          <input 
            type="text" 
            name="search_api_fulltext"
            id="services-search-input"
            class="services-search-input" 
            placeholder="Rechercher une démarche (ex : naissance, permis, acte ...)"
            autocomplete="off"
          />
          <button type="submit" class="services-search-btn" id="services-search-submit">
            <i class="fas fa-search me-2"></i>Rechercher
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
<!-- ===== FIN BANNIÈRE ===== -->

<!-- ===== CORPS DE LA PAGE : 2 COLONNES ===== -->
<div class="container services-page-body">
  <div class="row g-4">
    
    <!-- COLONNE GAUCHE : Liste des services (col-lg-8) -->
    <div class="col-lg-8 col-md-12">
      <div class="services-list-header">
        <h2 class="services-list-title">Tous les services</h2>
      </div>
      <div class="services-list-container">
      {# ================================================================
         Remplacez 'services_citoyens' par le nom machine de votre vue.
         'page_1' est le nom système du display Page.
         ================================================================ #}
        {{ drupal_view('services_citoyens', 'page_1') }}
      </div>
    </div>

    <!-- COLONNE DROITE : Sidebar des catégories (col-lg-4) -->
    <div class="col-lg-4 col-md-12">
      <div class="services-sidebar">
        
        <!-- Titre Catégories -->
        <div class="sidebar-header">
          <h3 class="sidebar-title">
            <i class="fas fa-list-ul me-2"></i>Catégories
          </h3>
        </div>

        <!-- Liste des catégories injectée via une vue Drupal -->
        <ul class="sidebar-categories-list">
          <li class="sidebar-category-item active">
            <a href="/services-aux-citoyens" class="sidebar-category-link">
              <span class="cat-label">Toutes les catégories</span>
              <span class="cat-arrow"><i class="fas fa-chevron-right"></i></span>
            </a>
          </li>
        </ul>
        
        {# ================================================================
           Le display 'block_categories' affiche la liste des termes du
           vocabulaire service_au_citoyen avec des liens filtrés.
           ================================================================ #}
        {{ drupal_view('services_citoyens', 'block_categories') }}

        <!-- Bloc aide -->
        <div class="sidebar-help-box">
          <div class="sidebar-help-icon">
            <i class="fas fa-headset"></i>
          </div>
          <div class="sidebar-help-content">
            <h5>Besoin d'aide ?</h5>
            <p>Contactez nos agents pour vous accompagner dans vos démarches.</p>
            <a href="/contact" class="sidebar-help-btn">
              <i class="fas fa-envelope me-2"></i>Nous contacter
            </a>
          </div>
        </div>

      </div>
    </div>

  </div>
</div>
<!-- ===== FIN CORPS DE LA PAGE ===== -->

{% if page.footer %}
    <section class="footer">
        <div class="container">
            <div class="footer-content ptb-100">
               <div class="row">
                 {{ page.footer }}
               </div>
            </div>
            <div class="copyright">
                <p>powered by <a target="_blank" href="">Agence pour le Développement du Numérique de Kinshasa (APDNK)</a></p>
            </div>
        </div>
    </section>
{% endif %}

{% if page.popup %}
    <div class="popup">
        {{page.popup}}
    </div>
{% endif %}
