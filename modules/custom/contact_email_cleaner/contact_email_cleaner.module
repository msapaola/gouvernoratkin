<?php

/**
 * @file
 * Contact Email Cleaner module.
 */

/**
 * Implements hook_mail_alter().
 */
function contact_email_cleaner_mail_alter(&$message) {
  // Only process contact form emails.
  if ($message['module'] === 'contact' && in_array($message['key'], ['page_mail', 'page_copy', 'user_mail', 'user_copy'])) {
    
    // Clean the body content by removing debug comments.
    if (!empty($message['body'])) {
      $cleaned_body = [];
      
      foreach ($message['body'] as $body_part) {
        // Convert to string and clean content.
        $body_string = is_string($body_part) ? $body_part : (string) $body_part;
        $cleaned_part = _contact_email_cleaner_clean_content($body_string);
        
        if (!empty($cleaned_part)) {
          $cleaned_body[] = $cleaned_part;
        }
      }
      
      if (!empty($cleaned_body)) {
        $message['body'] = $cleaned_body;
      }
    }
  }
}

/**
 * Clean content by removing debug comments and improving formatting.
 */
function _contact_email_cleaner_clean_content($content) {
  if (empty($content)) {
    return '';
  }
  
  // Remove Drupal debug comments.
  $content = preg_replace('/<!--\s*THEME DEBUG.*?-->/s', '', $content);
  $content = preg_replace('/<!--\s*FILE NAME SUGGESTIONS.*?-->/s', '', $content);
  $content = preg_replace('/<!--\s*BEGIN CUSTOM TEMPLATE OUTPUT.*?-->/s', '', $content);
  $content = preg_replace('/<!--\s*END CUSTOM TEMPLATE OUTPUT.*?-->/s', '', $content);
  $content = preg_replace('/<!--\s*💡.*?-->/s', '', $content);
  $content = preg_replace('/<!--\s*✅.*?-->/s', '', $content);
  
  // Remove any remaining HTML comments.
  $content = preg_replace('/<!--.*?-->/s', '', $content);
  
  // Remove empty lines and normalize spacing.
  $content = preg_replace('/\n\s*\n\s*\n/', "\n\n", $content);
  $content = preg_replace('/\s+/', ' ', $content);
  $content = trim($content);
  
  return $content;
} 